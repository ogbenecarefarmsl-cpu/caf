{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "pnpm run build && wrangler dev",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:android": "pnpm run build && pnpm exec cap sync android",
    "cap:open:android": "pnpm exec cap open android",
    "android:sync": "pnpm run build && pnpm exec cap sync android",
    "android:bundle": "pnpm run android:sync && .\\android\\gradlew.bat -p android bundleRelease",
    "android:apk": "pnpm run android:sync && .\\android\\gradlew.bat -p android assembleRelease",
    "android:clean": ".\\android\\gradlew.bat -p android clean",
    "live:update:build": "pnpm run build",
    "live:update:sync": "pnpm run build && pnpm exec cap sync",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-updater": "^7.0.0",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "dexie": "^4.2.1",
    "lucide-react": "^0.560.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.85.0"
  }
}
